# ─────────────────────────────────────────────────────────────────────────────
# Petware Ltd — Environment Variables
#
# Copy this file:  cp .env.local.example .env.local
# Fill in real values. NEVER commit .env.local — it is in .gitignore.
#
# For Vercel: add each variable under
#   Project Settings → Environment Variables → Production
# ─────────────────────────────────────────────────────────────────────────────


# ── NextAuth.js (required) ────────────────────────────────────────────────────
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_output_of_openssl_rand_base64_32
NEXTAUTH_URL=https://petware.co.nz


# ── Google OAuth 2.0 (Trade Login → "Sign in with Google") ───────────────────
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web app)
# 3. Authorised redirect URI: https://petware.co.nz/api/auth/callback/google
#    (for local dev add: http://localhost:3000/api/auth/callback/google)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
# Restrict SSO to a single Google Workspace domain. Set to * to allow all.
GOOGLE_ALLOWED_DOMAIN=petware.co.nz


# ── Jiwa WMS Integration ──────────────────────────────────────────────────────
# The Jiwa REST API runs as a Windows Service (JiwaAPISelfHostedService.exe).
# It must be publicly reachable. Use Cloudflare Tunnel for zero-config HTTPS:
#   https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/
# Or use a static IP with port forwarding and an SSL cert (Let's Encrypt).
JIWA_API_URL=https://jiwa.petware.co.nz:8080
JIWA_USERNAME=api_service_account
JIWA_PASSWORD=your_jiwa_api_password
# Shared secret for inbound Jiwa webhooks (stock/price change notifications).
# Set the same value in Jiwa → Settings → eCommerce → Webhooks → Secret Header.
# Generate: openssl rand -hex 32
JIWA_WEBHOOK_SECRET=replace_with_random_hex_string


# ── Email — Resend (recommended) ─────────────────────────────────────────────
# Sign up free at https://resend.com (100 emails/day free, ~$20/mo paid)
# Required for contact form and trade account application notifications.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@petware.co.nz
CONTACT_EMAIL=petware@petware.co.nz
TRADE_APPLICATION_EMAIL=accounts@petware.co.nz


# ── Demo / fallback trade accounts (CredentialsProvider) ─────────────────────
# Passwords are stored as bcrypt hashes — NEVER store plaintext passwords.
# To generate a hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
DEMO_EMAIL_1=trade@petware.co.nz
DEMO_HASH_1=replace_with_bcrypt_hash
DEMO_EMAIL_2=demo@petware.co.nz
DEMO_HASH_2=replace_with_bcrypt_hash


# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://petware.co.nz
